# Environment Variables for FoodDash
# Copy this file to .env and fill in your actual Supabase credentials

# ─── Supabase (REQUIRED) ────────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API

# Your project URL (format: https://xxxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Your anon/public key (the LONG eyJ... JWT key from Settings → API → Project API Keys)
# NOTE: Use the "anon public" key, NOT the "service_role" key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Optional: Backend API URL ───────────────────────────────────────────────
# Only needed if you're running the Node.js backend for Stripe payments
# VITE_API_URL=http://localhost:4242
